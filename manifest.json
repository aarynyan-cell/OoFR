{
  "manifest_version": 3,
  "name": "OoFR 法语发音练习器",
  "short_name": "OoFR",
  "version": "0.7.0",
  "description": "带专辑、磁带和单词本的法语发音练习工具。",
  "permissions": ["storage"],
  "action": {
    "default_title": "打开 OoFR",
    "default_icon": {
      "16": "icons/icon-192.png",
      "32": "icons/icon-192.png",
      "48": "icons/icon-192.png",
      "128": "icons/icon-192.png"
    }
  },
  "background": {
    "service_worker": "extension-service-worker.js"
  },
  "icons": {
    "16": "icons/icon-192.png",
    "32": "icons/icon-192.png",
    "48": "icons/icon-192.png",
    "128": "icons/icon-192.png"
  },
  "offline_enabled": true
}
