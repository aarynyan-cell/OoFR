{
  "manifest_version": 3,
  "name": "MulTape 外语磁带",
  "short_name": "MulTape",
  "version": "1.0.1",
  "description": "多语言磁带风格的外语朗读、学习记录和按需词库工具。",
  "permissions": ["storage"],
  "action": {
    "default_title": "打开 MulTape 外语磁带",
    "default_icon": {
      "16": "icons/icon-192.png",
      "32": "icons/icon-192.png",
      "48": "icons/icon-192.png",
      "128": "icons/icon-192.png"
    }
  },
  "background": {
    "service_worker": "extension-service-worker.js"
  },
  "icons": {
    "16": "icons/icon-192.png",
    "32": "icons/icon-192.png",
    "48": "icons/icon-192.png",
    "128": "icons/icon-192.png"
  },
  "offline_enabled": true
}
